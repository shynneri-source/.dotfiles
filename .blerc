# ~/.blerc
# --- 1. KEYBINDINGS (Fixing C-j) ---
ble-bind -f 'C-j' 'ble/widget/insert-newline'

# --- 2. SETTINGS ---
bleopt complete_auto_complete=1

# --- 3. COLORS (Safe & Silent Mode) ---
function my_safe_config {
    function _try_face {
        ble-face -s "$1" "$2" &>/dev/null
    }

    # Reset "Blocky" Backgrounds
    _try_face argument fg=default
    _try_face quote fg=default
    _try_face filename fg=default
    _try_face variable fg=default
    _try_face region bg=none,fg=blue,reverse

    # Red/Green Validation
    _try_face command_error fg=red,bold
    _try_face syntax_error fg=red,bold

    _try_face command_function fg=green
    _try_face command_alias fg=green
    _try_face command_builtin fg=green
    _try_face command_file fg=green

    # Ghost Hint
    _try_face auto_complete fg=244
}

# Run immediately (silently) to catch it if possible
my_safe_config

# AND run again when syntax loads (to ensure it sticks)
blehook/eval-after-load syntax my_safe_config
EOF
